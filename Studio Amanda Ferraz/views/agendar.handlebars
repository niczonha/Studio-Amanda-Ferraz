<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agendar - Studio Amanda Ferraz</title>
  <link rel="stylesheet" href="./../css/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    .agendar-container {
      min-height: 80vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 20px;
      gap: 20px;
    }

    .agendar-titulo {
      color: var(--marrom);
      font-size: 2.5rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 10px;
    }

    .agendar-subtitulo {
      color: var(--m-escuro);
      font-size: 1.2rem;
      text-align: center;
      margin-bottom: 40px;
    }

    .agendar-cards {
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .agendar-card {
      background: var(--bege);
      border-radius: 16px;
      padding: 40px 50px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      width: 280px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.1);
     
    }


    .agendar-card img {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--marrom);
    }

    .agendar-card h2 {
      color: var(--marrom);
      font-size: 1.5rem;
      font-weight: 700;
    }

    .agendar-card p {
      color: #555;
      font-size: 0.95rem;
    }

    .btn-wpp {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #25D366;
      color: white;
      font-size: 1rem;
      font-weight: 700;
      padding: 14px 28px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      margin-top: 8px;
    }

    .btn-wpp:hover {
      background: #1ebe5d;
      transform: translateY(-2px);
    }

    .btn-wpp i {
      font-size: 1.3rem;
    }

    @media (max-width: 768px) {
      .agendar-titulo {
        font-size: 1.8rem;
      }

      .agendar-cards {
        flex-direction: column;
        align-items: center;
      }

      .agendar-card {
        width: 100%;
        max-width: 320px;
        padding: 30px 24px;
      }
    }
  </style>
</head>
<body>


  <header>
    <nav class="navbar">
      <div class="logo">
        <img src="./../img/Studio Logo.png" alt="Logo do Studio">
      </div>
      <div class="hamburguer" id="hamburguer">
        <span></span>
        <span></span>
        <span></span>
      </div>
      <ul class="menu" id="menu">
        <li><a href="/">HOME</a></li>
        <li><a href="/#sobre">SOBRE</a></li>
        <li><a href="/#alisamento">SERVIÇOS</a></li>
        <li><a href="/#localizacao">LOCALIZAÇÃO</a></li>
        <li class="mobile-btn">
          <button class="btn-agendar">AGENDAR</button>
        </li>
      </ul>
      <button class="btn-agendar desktop-btn">AGENDAR</button>
    </nav>
  </header>

  <div class="agendar-container">
    <h1 class="agendar-titulo">AGENDE SEU HORÁRIO</h1>
    <p class="agendar-subtitulo">Escolha com qual profissional deseja agendar e fale direto pelo WhatsApp</p>

    <div class="agendar-cards">

      <!-- AMANDA -->
      <div class="agendar-card">
        <img src="./../img/amanda.png" alt="Amanda Ferraz">
        <h2>Amanda Ferraz</h2>
        <p>Especialista em Alisamento e Cabelos</p>
        <a class="btn-wpp" href="https://w.app/ih5cj4" target="_blank">
          <i class="fa-brands fa-whatsapp"></i> Agendar com Amanda
        </a>
      </div>

      <!-- EDUARDA -->
      <div class="agendar-card">
        <img src="./../img/eduarda.png" alt="Eduarda Ferraz">
        <h2>Eduarda Ferraz</h2>
        <p>Especialista em Extensão de Cílios</p>
        <a class="btn-wpp" href="https://w.app/23l1jk" target="_blank">
          <i class="fa-brands fa-whatsapp"></i> Agendar com Eduarda
        </a>
      </div>

    </div>
  </div>

  <script>
    const hamburguer = document.getElementById('hamburguer');
    const menu = document.querySelector('.menu');
    hamburguer.addEventListener('click', () => {
      hamburguer.classList.toggle('ativo');
      menu.classList.toggle('ativo');
    });
  </script>

</body>
</html>