<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redefinir Senha</title>
    <link rel="stylesheet" href="/css/RefindPassword.css">
</head>
<body>
    <div class="Main">
        <div class="image"><img src="/img/homem.png" alt=""></div>
        <div class="info">
            <div class="text">
                <h4>Redefinir a Senha</h4>
                <p>Digite a Sua nova senha</p>
            </div>
            <div class="info-dados">
                <input type="password" id="senha" placeholder="Senha">
                <p>Use pelo menos 8 caracteres</p>
                <p id="erro" style="color: red; font-size: 0.85rem; display: none;"></p>
            </div>
            <div class="btn">
                <button type="submit" onclick="redefinir()">Mudar</button>
            </div>
            <p id="confirmacao" style="display: none;">Senha alterada com sucesso!</p>
        </div>
    </div>
    <script src="/js/refindPassword.js"></script>
</body>
</html>