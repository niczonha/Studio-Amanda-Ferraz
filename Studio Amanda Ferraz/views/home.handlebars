  <script src="/js/script.js"></script>
  
  <script>
  const hamburguer = document.getElementById('hamburguer');
  const menu = document.querySelector('.menu');

  hamburguer.addEventListener('click', () => {
    hamburguer.classList.toggle('ativo');
    menu.classList.toggle('ativo');
  });
  </script>


<script>
  const estadoCarrossel = {};

  function initCarrossel(id) {
    const cards = document.querySelectorAll(`#track-${id} .card-servico`);
    estadoCarrossel[id] = { indice: 0, cards };
    renderizarDots(id);
    aplicarPosicao(id, false);
  }

  function cardsPorVez() {
    if (window.innerWidth <= 560) return 1;
    if (window.innerWidth <= 900) return 2;
    return 3;
  }

  function totalPaginas(id) {
    const total = estadoCarrossel[id].cards.length;
    return Math.max(1, total - cardsPorVez() + 1);
  }

  function renderizarDots(id) {
    const dots = document.getElementById(`dots-${id}`);
    const total = totalPaginas(id);
    if (total <= 1) { dots.innerHTML = ''; return; }

    dots.innerHTML = Array.from({ length: total }, (_, i) =>
      `<button class="dot ${i === estadoCarrossel[id].indice ? 'ativo' : ''}"
               onclick="irParaPagina('${id}', ${i})"></button>`
    ).join('');
  }

  function atualizarDots(id) {
    document.querySelectorAll(`#dots-${id} .dot`).forEach((dot, i) => {
      dot.classList.toggle('ativo', i === estadoCarrossel[id].indice);
    });
  }

  function aplicarPosicao(id, animado = true) {
    const track = document.getElementById(`track-${id}`);
    const container = track.closest('.carrossel-track-container');
    const cpv = cardsPorVez();
    const gap = 24;
    const cardLargura = (container.offsetWidth - gap * (cpv - 1)) / cpv;
    const deslocamento = estadoCarrossel[id].indice * (cardLargura + gap);

    track.style.transition = animado ? 'transform 0.45s cubic-bezier(0.4,0,0.2,1)' : 'none';
    track.style.transform = `translateX(-${deslocamento}px)`;

    document.getElementById(`prev-${id}`).disabled = estadoCarrossel[id].indice === 0;
    document.getElementById(`next-${id}`).disabled = estadoCarrossel[id].indice >= totalPaginas(id) - 1;

    atualizarDots(id);
  }

  function moverCarrossel(id, direcao) {
    const max = totalPaginas(id) - 1;
    estadoCarrossel[id].indice = Math.max(0, Math.min(estadoCarrossel[id].indice + direcao, max));
    aplicarPosicao(id);
  }

  function irParaPagina(id, pagina) {
    estadoCarrossel[id].indice = pagina;
    aplicarPosicao(id);
  }

  // Swipe mobile
  let touchStartX = 0;
  document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  document.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      ['alisamento', 'cilios'].forEach(id => {
        const track = document.getElementById(`track-${id}`);
        if (track && track.closest(':hover')) moverCarrossel(id, diff > 0 ? 1 : -1);
      });
    }
  });

  // Responsivo
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ['alisamento', 'cilios'].forEach(id => {
        renderizarDots(id);
        aplicarPosicao(id, false);
      });
    }, 150);
  });

  initCarrossel('alisamento');
  initCarrossel('cilios');
</script>

